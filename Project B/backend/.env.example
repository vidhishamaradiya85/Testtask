# Copy this file to .env and fill in real values.

# Required: API key for POST /shorten
API_KEY=your-secret-api-key-here

# Base URL used when constructing short URLs in the response
BASE_URL=http://localhost:8000

# Path to SQLite database file (relative to backend/)
DATABASE_PATH=urls.db

# Default TTL in days when no expires_at is given at creation (0 = never expire)
DEFAULT_EXPIRY_DAYS=30
